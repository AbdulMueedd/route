<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>VRP Route Optimizer | The Cary Company</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* Cary-inspired theme */
    --primary: #1f3f8f;
    --primary-dark: #15326f;
    --primary-light: #e8eefb;

    --accent: #b8d800;
    --accent-soft: #f4facf;

    --bg: #ffffff;
    --bg2: #f7f8fa;
    --bg3: #eef1f5;

    --text: #1a1f2b;
    --text2: #5f6675;
    --text3: #8c93a1;

    --silver: #a7a7a7;
    --border: rgba(20, 31, 61, 0.10);
    --border2: rgba(20, 31, 61, 0.20);

    --danger-bg: #fcebeb;
    --danger: #791f1f;
    --danger-border: rgba(180,40,40,.3);

    --success: #27500a;

    --radius: 10px;
    --radius-lg: 16px;

    --shadow-sm: 0 4px 10px rgba(0,0,0,0.04);
    --shadow-md: 0 10px 28px rgba(17, 24, 39, 0.08);
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background:
      linear-gradient(to bottom, #f3f6fb 0%, #eef2f7 100%);
    color: var(--text);
    min-height: 100vh;
  }

  .page {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }

  /* Header */
  .brand-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1.4rem;
  }

  .brand-card {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    padding: 1.2rem 1.2rem 1rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .brand-card::after {
    content: "";
    display: block;
    width: 100%;
    height: 5px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    border-radius: 999px;
    margin-top: 1rem;
  }

  .brand-logo {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 0.9rem;
  }

  .brand-logo img {
    max-width: 360px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  h1 {
    font-size: 24px;
    font-weight: 700;
    color: var(--primary-dark);
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 13px;
    color: var(--text3);
  }

  .lbl {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 10px;
  }

  .card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .field label {
    font-size: 12px;
    color: var(--text2);
    font-weight: 500;
  }

  input[type=text], input[type=number] {
    height: 38px;
    padding: 0 12px;
    border-radius: var(--radius);
    border: 1px solid var(--border2);
    background: var(--bg2);
    color: var(--text);
    font-size: 13px;
    font-family: inherit;
    width: 100%;
    transition: border-color .2s ease, box-shadow .2s ease, background .2s ease;
  }

  input:focus {
    outline: none;
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(31, 63, 143, 0.08);
  }

  .btn {
    height: 36px;
    padding: 0 14px;
    border-radius: var(--radius);
    border: 1px solid var(--border2);
    background: #fff;
    color: var(--text);
    font-size: 13px;
    font-family: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: all .2s ease;
    font-weight: 500;
  }

  .btn:hover {
    background: var(--bg2);
    transform: translateY(-1px);
  }

  .btn:active {
    transform: scale(.98);
  }

  .btn-p {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: #fff;
    border-color: var(--primary-dark);
    font-weight: 600;
    box-shadow: 0 8px 20px rgba(31, 63, 143, 0.18);
  }

  .btn-p:hover {
    opacity: .95;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  }

  .btn-d {
    color: var(--danger);
    border-color: var(--danger-border);
    background: #fff;
  }

  .btn-d:hover {
    background: var(--danger-bg);
  }

  .srow {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }

  .srow:last-child {
    border-bottom: none;
  }

  .snum {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--primary-light);
    border: 1px solid #c8d6f4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: var(--primary-dark);
    flex-shrink: 0;
  }

  .gbadge {
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 99px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .gok  { background: #eaf3de; color: #27500a; }
  .gfail{ background: #fcebeb; color: #791f1f; }
  .gpend{ background: #eef1f5; color: var(--text3); }

  .badge {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 99px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .dbadge {
    background: var(--primary-light);
    color: var(--primary-dark);
  }

  .sgrid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 10px;
    margin-bottom: 1rem;
  }

  .metric {
    background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
    border-radius: var(--radius-lg);
    padding: 14px 14px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }

  .mval {
    font-size: 24px;
    font-weight: 700;
    color: var(--primary-dark);
  }

  .mlbl {
    font-size: 11px;
    color: var(--text3);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  .rcard {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: 12px;
    overflow: hidden;
    background: var(--bg);
    box-shadow: var(--shadow-sm);
  }

  .rhead {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
  }

  .rstops {
    padding: 0 14px;
  }

  .rstop {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }

  .rstop:last-child {
    border-bottom: none;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 2px solid;
    flex-shrink: 0;
  }

  .vl {
    width: 2px;
    height: 14px;
    background: var(--border2);
    margin: 0 auto;
  }

  .mtable {
    width: 100%;
    font-size: 11px;
    border-collapse: collapse;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
  }

  .mtable th {
    color: var(--text3);
    font-weight: 600;
    padding: 8px 8px;
    text-align: right;
    background: #f7f9fc;
    border-bottom: 1px solid var(--border);
  }

  .mtable td {
    padding: 8px 8px;
    text-align: right;
    color: var(--text2);
    border-top: 1px solid var(--border);
  }

  .mtable td:first-child {
    text-align: left;
    color: var(--text);
    font-weight: 600;
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .mtable tr:hover td {
    background: #f8fbff;
  }

  .tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 1.2rem;
    background: rgba(255,255,255,0.7);
    padding: 6px;
    border-radius: 14px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(6px);
  }

  .tab {
    flex: 1;
    padding: 10px 14px;
    font-size: 13px;
    cursor: pointer;
    color: var(--text2);
    border-radius: 10px;
    text-align: center;
    user-select: none;
    transition: all .2s ease;
    font-weight: 500;
  }

  .tab.on {
    color: #fff;
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    box-shadow: 0 8px 18px rgba(31, 63, 143, 0.16);
  }

  .tab:hover:not(.on) {
    color: var(--primary-dark);
    background: #f4f7fc;
  }

  .pane {
    display: none;
  }

  .pane.on {
    display: block;
  }

  .ebox {
    background: var(--danger-bg);
    border: 1px solid var(--danger-border);
    border-radius: var(--radius);
    padding: 10px 14px;
    font-size: 13px;
    color: var(--danger);
    margin-bottom: 10px;
  }

  .spin {
    display: inline-block;
    width: 13px;
    height: 13px;
    border: 2px solid rgba(255,255,255,.35);
    border-top-color: #fff;
    border-radius: 50%;
    animation: sp .7s linear infinite;
    vertical-align: -2px;
  }

  @keyframes sp {
    to { transform: rotate(360deg); }
  }

  .fleet-row {
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  .fleet-row .field input {
    width: 90px;
  }

  .url-row {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
  }

  .url-row input {
    flex: 1;
  }

  #pstat {
    font-size: 12px;
    color: var(--text3);
  }

  @media (max-width: 720px) {
    .sgrid {
      grid-template-columns: 1fr;
    }

    .fleet-row {
      flex-direction: column;
      align-items: stretch;
    }

    .fleet-row .field input {
      width: 100%;
    }

    .url-row {
      flex-direction: column;
      align-items: stretch;
    }

    .brand-logo img {
      max-width: 280px;
    }

    h1 {
      font-size: 20px;
    }
  }
</style>
</head>
<body>
<div class="page">

  <!-- Header / Logo -->
  <div class="brand-wrap">
    <div class="brand-card">
      <div class="brand-logo">
        image.png
      </div>
      <h1>VRP Route Optimizer</h1>
      <p class="subtitle">Powered by OSRM real road data + Google OR-Tools</p>
    </div>
  </div>

  <div class="tabs">
    <div class="tab on" onclick="st('config')">Configuration</div>
    <div class="tab" onclick="st('results')">Results</div>
    <div class="tab" onclick="st('matrix')">Distance matrix</div>
  </div>

  <!-- CONFIG -->
  <div class="pane on" id="pane-config">
    <p class="lbl">Backend</p>
    <div class="card" style="margin-bottom:12px;">
      <div class="url-row">
        <input type="text" id="burl" value="http://localhost:5000" />
        <button class="btn" onclick="ping()" id="pbtn">
          <i class="ti ti-wifi"></i> Test connection
        </button>
      </div>
      <div id="pstat">Not tested — make sure Flask is running first.</div>
    </div>

    <p class="lbl">Depot</p>
    <div class="card" style="margin-bottom:12px;">
      <div class="srow">
        <div class="snum" style="background:#e8eefb;border-color:#bfd0f5;color:#15326f;">D</div>
        <input type="text" id="depot" value="Addison, IL" style="flex:1;"
          oninput="DC=null;sb('gbdepot','not geocoded','gpend')" />
        <span id="gbdepot" class="gbadge gpend">not geocoded</span>
        <span class="badge dbadge">depot</span>
      </div>
    </div>

    <p class="lbl">Delivery stops</p>
    <div class="card">
      <div id="sc"></div>
      <button class="btn" onclick="addS()" style="margin-top:8px;width:100%;justify-content:center;">
        <i class="ti ti-plus"></i> Add stop
      </button>
    </div>

    <p class="lbl">Fleet</p>
    <div class="card">
      <div class="fleet-row">
        <div class="field"><label>Trucks</label><input type="number" id="nt" value="3" min="1" max="20" style="width:70px;" /></div>
        <div class="field"><label>Capacity each</label><input type="number" id="cap" value="100" min="1" /></div>
        <div class="field"><label>Service time (min)</label><input type="number" id="svc" value="20" min="0" /></div>
      </div>
    </div>

    <div id="serr" style="display:none;" class="ebox"></div>
    <button class="btn btn-p" id="sbtn" onclick="solve()"
      style="width:100%;justify-content:center;height:44px;font-size:14px;">
      <i class="ti ti-route"></i> Optimize routes
    </button>
  </div>

  <!-- RESULTS -->
  <div class="pane" id="pane-results">
    <div id="rc"><p style="color:var(--text3);font-size:13px;">Run the optimizer to see results.</p></div>
  </div>

  <!-- MATRIX -->
  <div class="pane" id="pane-matrix">
    <div id="mc"><p style="color:var(--text3);font-size:13px;">Run the optimizer to see matrices.</p></div>
  </div>
</div>

<script>
const COLORS=[
  {bg:'#e8eefb',br:'#9fb8f5',tx:'#15326f',dt:'#1f3f8f'},
  {bg:'#eef7da',br:'#c8dd5f',tx:'#3c4d00',dt:'#9ab400'},
  {bg:'#f0f2f5',br:'#c5cad4',tx:'#394150',dt:'#7d8593'},
  {bg:'#e7f0ff',br:'#89aef5',tx:'#102f70',dt:'#3f6edb'},
  {bg:'#f8f9fc',br:'#b8c0ce',tx:'#2c3443',dt:'#758195'},
];

let S=[
  {name:"O'Hare Airport, Chicago, IL", demand:30, coords:null},
  {name:"Willis Tower, Chicago, IL",   demand:40, coords:null},
  {name:"Navy Pier, Chicago, IL",      demand:40, coords:null},
  {name:"Schaumburg, IL",              demand:30, coords:null},
];
let DC=null;
const GC={};

function sb(id,txt,cls){
  const e=document.getElementById(id);
  if(!e)return;
  e.textContent=txt;
  e.className='gbadge '+cls;
}

function base(){return document.getElementById('burl').value.replace(/\/$/,'');}

function ft(m){
  const t=480+m, h=Math.floor(t/60), mm=t%60;
  return `${h}:${mm.toString().padStart(2,'0')}`;
}

function st(t){
  document.querySelectorAll('.tab').forEach(e=>e.classList.remove('on'));
  document.querySelectorAll('.pane').forEach(e=>e.classList.remove('on'));
  const idx={config:0,results:1,matrix:2}[t];
  document.querySelectorAll('.tab')[idx].classList.add('on');
  document.getElementById('pane-'+t).classList.add('on');
}

async function geo(q){
  if(GC[q])return GC[q];
  const r=await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=1`,
    {headers:{'Accept-Language':'en'}});
  const d=await r.json();
  if(!d.length)return null;
  const v=[parseFloat(d[0].lat),parseFloat(d[0].lon)];
  GC[q]=v;
  return v;
}

function rs(){
  const c=document.getElementById('sc');
  c.innerHTML='';
  S.forEach((s,i)=>{
    const d=document.createElement('div');
    d.className='srow';
    d.innerHTML=`
      <div class="snum">${i+1}</div>
      <input type="text" value="${s.name.replace(/"/g,'&quot;')}" placeholder="Place name, City, State" style="flex:1;"
        oninput="S[${i}].name=this.value;S[${i}].coords=null;sb('gb${i}','not geocoded','gpend')" />
      <div class="field" style="flex-shrink:0;">
        <label style="font-size:11px;">Demand</label>
        <input type="number" value="${s.demand}" min="0" style="width:64px;"
          oninput="S[${i}].demand=parseInt(this.value)||0" />
      </div>
      <span id="gb${i}" class="gbadge ${s.coords?'gok':'gpend'}">${s.coords?'✓ located':'not geocoded'}</span>
      <button class="btn btn-d" onclick="rmS(${i})" style="padding:0 8px;height:30px;" title="Remove stop">
        <i class="ti ti-trash"></i>
      </button>`;
    c.appendChild(d);
  });
}

function addS(){ S.push({name:'',demand:20,coords:null}); rs(); }
function rmS(i){ S.splice(i,1); rs(); }

async function ping(){
  const btn=document.getElementById('pbtn');
  const ps=document.getElementById('pstat');
  btn.disabled=true;
  btn.innerHTML='<span class="spin" style="border-color:#ccc;border-top-color:#333;"></span> Testing…';
  try{
    const r=await fetch(base()+'/solve');
    ps.style.color=r.ok?'#27500a':'#791f1f';
    ps.textContent=r.ok?'✓ Connected — Flask server is reachable.':`Server returned ${r.status}. Check Flask logs.`;
  }catch(e){
    ps.style.color='#791f1f';
    ps.textContent='Cannot reach server. Run: python your_script.py';
  }finally{
    btn.innerHTML='<i class="ti ti-wifi"></i> Test connection';
    btn.disabled=false;
  }
}

function setBtn(msg){
  document.getElementById('sbtn').innerHTML=
    `<span class="spin"></span> <span style="font-size:12px;opacity:.9;">${msg}</span>`;
}

async function solve(){
  const btn=document.getElementById('sbtn');
  const err=document.getElementById('serr');
  err.style.display='none';
  btn.disabled=true;

  try{
    if(!S.length) throw new Error('Add at least one delivery stop.');

    const dn=document.getElementById('depot').value.trim();
    if(!dn) throw new Error('Enter a depot location.');

    if(!DC){
      setBtn('Geocoding depot…');
      sb('gbdepot','looking up…','gpend');
      const c=await geo(dn);
      if(!c){ sb('gbdepot','not found','gfail'); throw new Error(`Could not find depot: "${dn}"`); }
      DC=c;
      sb('gbdepot','✓ located','gok');
    }

    for(let i=0;i<S.length;i++){
      if(!S[i].name.trim()) throw new Error(`Stop ${i+1} has no name.`);
      if(!S[i].coords){
        setBtn(`Geocoding stop ${i+1} of ${S.length}…`);
        sb(`gb${i}`,'looking up…','gpend');
        const c=await geo(S[i].name);
        if(!c){ sb(`gb${i}`,'not found','gfail'); throw new Error(`Could not find: "${S[i].name}"`); }
        S[i].coords=c;
        sb(`gb${i}`,'✓ located','gok');
      }
    }

    setBtn('Running OR-Tools via Flask…');

    const payload={
      depot: dn,
      depot_coords: DC,
      stops: S.map(s=>({name:s.name, demand:s.demand, coords:s.coords})),
      num_trucks: parseInt(document.getElementById('nt').value)||3,
      truck_capacity: parseInt(document.getElementById('cap').value)||100,
      service_time: parseInt(document.getElementById('svc').value)||20,
    };

    const res=await fetch(base()+'/solve',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(payload),
    });

    if(!res.ok){
      const e=await res.json().catch(()=>({error:`HTTP ${res.status}`}));
      throw new Error(e.error||`HTTP ${res.status}`);
    }

    const data=await res.json();
    if(data.error) throw new Error(data.error);

    renderR(data);
    renderM(data);
    st('results');

  }catch(e){
    err.textContent='Error: '+e.message;
    err.style.display='block';
  }finally{
    btn.disabled=false;
    btn.innerHTML='<i class="ti ti-route"></i> Optimize routes';
  }
}

function renderR(data){
  const locs=data.locations;
  const active=data.routes.filter(r=>r.stops&&r.stops.length>2);
  const ts=active.reduce((s,r)=>s+(r.stops.length-2),0);

  let h=`<div class="sgrid">
    <div class="metric"><div class="mval">${Number(data.total_distance_km).toFixed(1)} km</div><div class="mlbl">Total distance</div></div>
    <div class="metric"><div class="mval">${active.length}</div><div class="mlbl">Trucks used</div></div>
    <div class="metric"><div class="mval">${ts}</div><div class="mlbl">Stops covered</div></div>
  </div>`;

  data.routes.forEach((r,vi)=>{
    if(!r.stops||r.stops.length<=2)return;
    const c=COLORS[vi%COLORS.length];
    const ret=r.stops[r.stops.length-1];
    h+=`<div class="rcard">
      <div class="rhead" style="background:${c.bg};">
        <div style="width:34px;height:34px;border-radius:10px;background:${c.br};color:${c.tx};display:flex;align-items:center;justify-content:center;font-size:16px;">
          <i class="ti ti-truck"></i>
        </div>
        <div style="flex:1;">
          <div style="font-weight:700;font-size:14px;color:${c.tx};">Truck ${r.truck}</div>
          <div style="font-size:12px;color:${c.tx};opacity:.75;">${r.load}/${r.capacity} units &nbsp;·&nbsp; ${r.stops.length-2} stop${r.stops.length-2!==1?'s':''}</div>
        </div>
        <span class="badge" style="background:${c.br};color:${c.tx};">back by ${ft(ret.arrival)}</span>
      </div>
      <div class="rstops">`;

    r.stops.forEach((step,si)=>{
      const isD=step.node===0, isL=si===r.stops.length-1;
      const dc=isD?'#1f3f8f':c.dt;
      h+=`<div class="rstop">
        <div style="display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:12px;">
          <div class="dot" style="border-color:${dc};background:${isD?dc:'transparent'};"></div>
          ${!isL?`<div class="vl"></div>`:''}
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:13px;font-weight:${isD?'700':'500'};overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${locs[step.node]}</div>
          ${isD?`<span class="badge dbadge">${si===0?'depart':'return'}</span>`:`<div style="font-size:11px;color:var(--text3);">stop ${si}</div>`}
        </div>
        <div style="font-size:13px;color:#6f7785;font-variant-numeric:tabular-nums;flex-shrink:0;">${ft(step.arrival)}</div>
      </div>`;
    });
    h+=`</div></div>`;
  });

  document.getElementById('rc').innerHTML=h;
}

function renderM(data){
  const names=data.locations;
  const short=names.map(n=>n.length>13?n.slice(0,13)+'…':n);

  const mk=(M,unit)=>{
    let t=`<div style="overflow-x:auto;margin-bottom:1.5rem;"><table class="mtable"><tr><th></th>`;
    short.forEach(n=>{t+=`<th>${n}</th>`;});
    t+='</tr>';
    M.forEach((row,i)=>{
      t+=`<tr><td>${short[i]}</td>`;
      row.forEach((v,j)=>{
        const self=i===j;
        t+=`<td style="${self?'color:#bbb;':''}">${self?'—':unit==='km'?Number(v).toFixed(2):v}</td>`;
      });
      t+='</tr>';
    });
    return t+`</table></div>`;
  };

  document.getElementById('mc').innerHTML=
    `<p class="lbl" style="margin-bottom:8px;">Distance (km) — real road data via OSRM</p>${mk(data.distances,'km')}`+
    `<p class="lbl" style="margin-bottom:8px;">Travel time (min) — real road data via OSRM</p>${mk(data.times,'min')}`;
}

rs();
</script>
